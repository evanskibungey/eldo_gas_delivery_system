# ─── Core ────────────────────────────────────────────────────────────────────
APP_NAME="EldoGas"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.co.ke
APP_TIMEZONE=Africa/Nairobi

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eldogas_production
DB_USERNAME=forge
DB_PASSWORD=

# ─── Session & Cache ─────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.co.ke
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=redis
CACHE_PREFIX=eldogas_

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Queue ───────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ─── Broadcasting (Laravel Reverb) ───────────────────────────────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https

REVERB_ALLOWED_ORIGINS=https://yourdomain.co.ke
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=60
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@eldogas.co.ke"
MAIL_FROM_NAME="EldoGas"

# ─── File Storage ────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
# Use s3 for cloud storage:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=af-south-1
# AWS_BUCKET=eldogas-storage
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Africa's Talking (SMS) ──────────────────────────────────────────────────
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=EldoGas
AT_DEV_MODE=false

# ─── M-Pesa ──────────────────────────────────────────────────────────────────
MPESA_ENVIRONMENT=production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_TILL_NUMBER=
MPESA_CALLBACK_URL="${APP_URL}/api/v1/payments/mpesa/callback"

# ─── Shop Settings ───────────────────────────────────────────────────────────
SHOP_OPENING_HOUR=7
SHOP_CLOSING_HOUR=21
SHOP_MANAGER_PHONE=

# ─── Vite ────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
